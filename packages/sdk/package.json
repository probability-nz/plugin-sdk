{
  "name": "@probability-nz/plugin-sdk",
  "version": "0.0.1",
  "description": "SDK for building probability.nz plugins",
  "type": "module",
  "license": "MIT",
  "author": "Garbo Succus",
  "repository": {
    "type": "git",
    "url": "https://github.com/probability-nz/plugin-sdk",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/probability-nz/plugin-sdk#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "oxlint -c ../../.oxlintrc.json && tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4",
    "@probability-nz/plugin-types": "workspace:*",
    "zustand": "^5.0.11"
  },
  "peerDependencies": {
    "@automerge/automerge": "^3",
    "@automerge/react": "^2.5.3",
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@automerge/automerge": "^3.2.3",
    "@automerge/react": "2.5.3",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.13",
    "jsdom": "^28.0.0",
    "react": "^19.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
