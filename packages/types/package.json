{
  "name": "@probability-nz/plugin-types",
  "version": "0.0.1",
  "description": "Shared types for probability.nz plugins",
  "type": "module",
  "license": "MIT",
  "author": "Garbo Succus",
  "repository": {
    "type": "git",
    "url": "https://github.com/probability-nz/plugin-sdk",
    "directory": "packages/types"
  },
  "homepage": "https://github.com/probability-nz/plugin-sdk#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./schema": "./dist/schema.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc && node scripts/generate-schema.mjs",
    "lint": "oxlint -c ../../.oxlintrc.json && tsc --noEmit"
  },
  "devDependencies": {
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^5.9.3"
  }
