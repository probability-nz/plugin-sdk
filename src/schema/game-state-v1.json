{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "templates": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/PieceTemplate" }
    },
    "states": {
      "type": "array",
      "items": { "$ref": "#/$defs/Scenario" }
    },
    "children": {
      "type": "array",
      "items": { "$ref": "#/$defs/Piece" }
    }
  },
  "$defs": {
    "Vector3Tuple": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3
    },
    "Face": {
      "type": "object",
      "required": ["name", "rotation"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "rotation": { "$ref": "#/$defs/Vector3Tuple" }
      }
    },
    "Piece": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "src": { "type": "string" },
        "template": { "type": "string" },
        "position": { "$ref": "#/$defs/Vector3Tuple" },
        "scale": { "$ref": "#/$defs/Vector3Tuple" },
        "rotation": { "$ref": "#/$defs/Vector3Tuple" },
        "color": { "type": ["string", "null"] },
        "locked": { "type": "boolean" },
        "faces": {
          "type": "array",
          "items": { "$ref": "#/$defs/Face" }
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/Piece" }
        }
      }
    },
    "PieceTemplate": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "src": { "type": "string" },
        "template": { "type": "string" },
        "position": { "$ref": "#/$defs/Vector3Tuple" },
        "scale": { "$ref": "#/$defs/Vector3Tuple" },
        "rotation": { "$ref": "#/$defs/Vector3Tuple" },
        "color": { "type": ["string", "null"] },
        "locked": { "type": "boolean" },
        "faces": {
          "type": "array",
          "items": { "$ref": "#/$defs/Face" }
        }
      }
    },
    "Scenario": {
      "type": "object",
      "required": ["children"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/Piece" }
        }
      }
    },
    "AnchoredPath": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "string" },
          { "type": "integer", "minimum": 0 }
        ]
      }
    },
    "CursorOp": {
      "type": "object",
      "required": ["action", "path"],
      "additionalProperties": false,
      "properties": {
        "action": { "const": "focus" },
        "path": { "$ref": "#/$defs/AnchoredPath" }
      }
    },
    "PutOp": {
      "type": "object",
      "required": ["action", "path", "value"],
      "additionalProperties": true,
      "properties": {
        "action": { "const": "put" },
        "path": { "$ref": "#/$defs/AnchoredPath" },
        "value": {}
      }
    },
    "MoveOp": {
      "type": "object",
      "required": ["action", "path", "to"],
      "additionalProperties": false,
      "properties": {
        "action": { "const": "move" },
        "path": { "$ref": "#/$defs/AnchoredPath" },
        "to": { "$ref": "#/$defs/AnchoredPath" }
      }
    },
    "PresenceState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cursor": { "$ref": "#/$defs/CursorOp" },
        "op": {
          "oneOf": [
            { "$ref": "#/$defs/PutOp" },
            { "$ref": "#/$defs/MoveOp" }
          ]
        }
      }
    }
  }
}
